# wip/ artifacts are committed to feature branches during workflows
# and cleaned before merge. Do NOT gitignore wip/.

# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/
# Claude Code local state (not committed)
.claude/*
# But commit the project settings (plugins, permissions)
!.claude/settings.json

# Eval workspaces (generated outputs, not committed)
**/evals/workspace/

# Eval viewer artifacts
decision-workspace/
.local.env

# Local overlay files (e.g. CLAUDE.local.md)
*.local*
